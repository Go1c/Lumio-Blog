{
  "name": "@opennote/cli",
  "version": "0.6.0",
  "type": "module",
  "bin": {
    "opennote": "./src/main.ts"
  },
  "scripts": {
    "start": "tsx src/main.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opennote/core": "workspace:*",
    "@opennote/db": "workspace:*",
    "@opennote/server": "workspace:*",
    "@opennote/sync": "workspace:*",
    "@opennote/web-public": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.16.5",
    "typescript": "^5.5.4"
  }
}
